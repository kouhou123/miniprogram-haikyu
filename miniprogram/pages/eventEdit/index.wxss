/* pages/eventEdit/index.wxss */
.page {
  min-height: 100vh;
  padding: 24rpx 0 180rpx;
}

.form {
  padding: 8rpx 28rpx;
}

.field {
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.field:last-child {
  border-bottom: none;
}
.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 18rpx;
}
.input {
  font-size: 28rpx;
}
.textarea {
  width: 100%;
  min-height: 180rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.datetime {
  display: flex;
  gap: 20rpx;
}
.picker {
  flex: 1;
  background: #f5f6f8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  text-align: center;
}

.cover-box {
  width: 100%;
  height: 280rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f5f6f8;
}
.cover-preview {
  width: 100%;
  height: 100%;
}
.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 28rpx;
}

.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 高亮有活动的日期为橙色 */
.van-calendar .has-event {
  background-color: #ff8c00 !important;
  color: #fff !important;
  border-radius: 6rpx !important;
}
