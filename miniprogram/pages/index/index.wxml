<!--pages/index/index.wxml-->
<view class="page">
  <view class="header">
    <view class="header-title">活动日历</view>
  </view>

  <van-cell title="选择单个日期" value="{{ dateLabel }}" is-link bind:click="onDisplay" />

  <van-calendar
    show="{{ showCalendar }}"
    show-confirm="{{ false }}"
    min-date="{{ minDate }}"
    max-date="{{ maxDate }}"
    default-date="{{ selectedDate }}"
    bind:close="onCloseCalendar"
    bind:confirm="onConfirmDate"
  />

  <view class="day-head">{{ dateLabel }} 的活动</view>

  <view wx:if="{{ dayLoading }}" class="muted loading">加载中...</view>
  <view wx:elif="{{ dayEvents.length === 0 }}" class="empty">这一天暂无活动</view>

  <view wx:else class="list">
    <view class="card event" wx:for="{{dayEvents}}" wx:key="_id">
      <view class="event-body">
        <view class="event-head">
          <text class="event-title">{{item.title}}</text>
          <text class="tag tag-{{item.status}}">{{item.statusText}}</text>
        </view>
        <view class="event-meta">🕒 {{item.timeText}}</view>
        <view class="event-meta" wx:if="{{item.location}}">📍 {{item.location}}</view>
        <view class="event-foot">
          <text class="event-count">已报名 {{item.enrolledCount}}/{{item.capacity}}</text>
          <text class="event-remain" wx:if="{{item.status === 'open'}}">剩余 {{item.remaining}}</text>
        </view>
        <view class="event-actions">
          <view class="btn-ghost act" data-id="{{item._id}}" bindtap="goDetail">查看</view>
          <view wx:if="{{item.registered}}" class="btn-danger act" data-id="{{item._id}}" bindtap="onCancel">取消报名</view>
          <view wx:elif="{{item.status === 'open'}}" class="btn-primary act" data-id="{{item._id}}" bindtap="onRegister">报名</view>
          <view wx:else class="btn-primary act disabled">{{item.statusText}}</view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{isOrganizer}}" class="fab" bindtap="goCreate">＋</view>
</view>
