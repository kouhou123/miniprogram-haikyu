/* pages/index/index.wxss */
.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 24rpx 16rpx;
}
.header-title {
  font-size: 40rpx;
  font-weight: 600;
}

.day-head {
  font-size: 30rpx;
  font-weight: 600;
  padding: 28rpx 24rpx 8rpx;
  color: #333;
}
.hint {
  margin: 8rpx 24rpx 0;
  color: #ff7a18;
  font-size: 24rpx;
}

.event {
  padding: 0;
  overflow: hidden;
}
.event.clickable {
  transition: transform 0.1s ease, background 0.1s ease;
}
.event.clickable:active {
  transform: scale(0.99);
  background: #fff6ef;
}
.event-body {
  padding: 24rpx 28rpx;
}
.event-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.event-title {
  font-size: 32rpx;
  font-weight: 600;
  flex: 1;
  margin-right: 16rpx;
}
.event-meta {
  color: #666;
  font-size: 24rpx;
  margin-top: 12rpx;
}
.event-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 18rpx;
}
.event-count {
  font-size: 24rpx;
  color: #333;
}
.event-remain {
  font-size: 24rpx;
  color: #ff7a18;
}

.event-tip {
  margin-top: 18rpx;
  font-size: 24rpx;
}
.tip-open {
  color: #ff7a18;
  font-weight: 600;
}
.tip-done {
  color: #52c41a;
  font-weight: 600;
}
.tip-muted {
  color: #999;
}

.event-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}
.act {
  flex: 1;
  padding: 16rpx 0;
  font-size: 26rpx;
}
.act.disabled {
  background: #c4c9d4;
}
.act-delete {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 12rpx;
}

.loading {
  text-align: center;
  padding: 24rpx 0;
}

.calendar-day-active {
  color: #f59a23;
  font-weight: 600;
}

.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 20;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
}
.modal {
  width: 100%;
  box-sizing: border-box;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 28rpx calc(32rpx + env(safe-area-inset-bottom));
}
.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}
.modal-sub {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}
.form-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.form-row.top {
  align-items: flex-start;
}
.form-label {
  width: 110rpx;
  color: #333;
  font-size: 28rpx;
}
.form-input {
  flex: 1;
  font-size: 28rpx;
}
.form-textarea {
  flex: 1;
  min-height: 150rpx;
  font-size: 28rpx;
  line-height: 1.5;
}
.modal-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}
.flex1 {
  flex: 1;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #ff7a18;
  color: #fff;
  font-size: 60rpx;
  line-height: 96rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 122, 24, 0.4);
}
