/* pages/eventDetail/index.wxss */
.page {
  min-height: 100vh;
  padding-bottom: 160rpx;
}

.cover {
  width: 100%;
  height: 360rpx;
  display: block;
  background: #eee;
}

.card {
  margin-top: 24rpx;
}

.title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.title {
  font-size: 38rpx;
  font-weight: 700;
  flex: 1;
  margin-right: 16rpx;
}
.meta {
  color: #555;
  font-size: 26rpx;
  margin-top: 16rpx;
}
.count-row {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #333;
}
.remain {
  color: #ff7a18;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.link {
  color: #ff7a18;
  font-size: 26rpx;
  font-weight: 400;
}
.desc {
  color: #444;
  font-size: 28rpx;
  line-height: 1.7;
  white-space: pre-wrap;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.photo-item {
  position: relative;
  width: 210rpx;
  height: 210rpx;
}
.photo-item image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}
.photo-del {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 36rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  border-radius: 50%;
  font-size: 28rpx;
}

.roster-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.roster-main {
  flex: 1;
  min-width: 0;
}
.roster-name {
  font-size: 28rpx;
  font-weight: 600;
}
.roster-remark {
  color: #555;
  font-size: 26rpx;
  line-height: 1.5;
  margin-top: 8rpx;
  white-space: pre-wrap;
}
.roster-actions {
  display: flex;
  gap: 20rpx;
  margin-left: 20rpx;
  white-space: nowrap;
}
.action-link {
  font-size: 26rpx;
}
.danger-link {
  color: #ff4d4f;
}

.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 20;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
}
.modal {
  width: 100%;
  box-sizing: border-box;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 28rpx calc(32rpx + env(safe-area-inset-bottom));
}
.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}
.form-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.form-row.top {
  align-items: flex-start;
}
.form-label {
  width: 110rpx;
  color: #333;
  font-size: 28rpx;
}
.form-input {
  flex: 1;
  font-size: 28rpx;
}
.form-textarea {
  flex: 1;
  min-height: 150rpx;
  font-size: 28rpx;
  line-height: 1.5;
}
.modal-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 16rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}
.flex1 {
  flex: 1;
}
