<!--pages/profile/index.wxml-->
<view class="page">
  <!-- 用户信息 -->
  <view class="card profile">
    <image class="avatar" src="{{user.avatarUrl || '/images/icons/customer-service.svg'}}" mode="aspectFill"></image>
    <view class="info">
      <view class="nick">{{user.nickName || '微信用户'}}</view>
      <view class="role">
        <text class="role-badge {{isOrganizer ? 'organizer' : ''}}">
          {{isOrganizer ? '活动组织者' : '普通用户'}}
        </text>
      </view>
    </view>
    <view class="edit-link" bindtap="startEdit">编辑</view>
  </view>

  <!-- 编辑表单 -->
  <view class="card" wx:if="{{editing}}">
    <view class="section-title">编辑资料</view>
    <view class="edit-row">
      <text class="edit-label">头像</text>
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image class="avatar-sm" src="{{form.avatarUrl || '/images/icons/customer-service.svg'}}" mode="aspectFill"></image>
      </button>
    </view>
    <view class="edit-row">
      <text class="edit-label">昵称</text>
      <input class="edit-input" type="nickname" placeholder="请输入昵称" value="{{form.nickName}}" bindinput="onNickInput" />
    </view>
    <view class="edit-row">
      <text class="edit-label">手机号</text>
      <input class="edit-input" type="number" placeholder="选填" value="{{form.phone}}" bindinput="onPhoneInput" />
    </view>
    <view class="edit-actions">
      <view class="btn-ghost flex1" bindtap="cancelEdit">取消</view>
      <view class="btn-primary flex1" bindtap="saveProfile">保存</view>
    </view>
  </view>

  <!-- 组织者入口 -->
  <view class="card" wx:if="{{isOrganizer}}">
    <view class="menu-item" bindtap="goCreate">
      <text>发布新活动</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <view wx:if="{{!isOrganizer}}" class="tip card">
    成为活动组织者后即可发布活动。请联系管理员将你的 openid 加入组织者白名单。
  </view>
</view>
