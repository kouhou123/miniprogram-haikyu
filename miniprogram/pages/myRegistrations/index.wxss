/* pages/myRegistrations/index.wxss */
.page {
  min-height: 100vh;
  padding-top: 24rpx;
}

.loading {
  text-align: center;
  padding: 60rpx 0;
}

.reg-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.reg-title {
  font-size: 32rpx;
  font-weight: 600;
  flex: 1;
  margin-right: 16rpx;
}
.reg-meta {
  color: #666;
  font-size: 24rpx;
  margin-top: 12rpx;
}
.reg-remark {
  color: #333;
  font-size: 26rpx;
  line-height: 1.5;
  margin-top: 14rpx;
  white-space: pre-wrap;
}
.admin-note {
  margin-top: 12rpx;
}
.reg-actions {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
  margin-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 20rpx;
}
.small {
  padding: 12rpx 32rpx;
  font-size: 26rpx;
}
.flex1 {
  flex: 1;
}

.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 20;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
}
.modal {
  width: 100%;
  box-sizing: border-box;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 28rpx calc(32rpx + env(safe-area-inset-bottom));
}
.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}
.form-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.form-row.top {
  align-items: flex-start;
}
.form-label {
  width: 110rpx;
  color: #333;
  font-size: 28rpx;
}
.form-input {
  flex: 1;
  font-size: 28rpx;
}
.form-textarea {
  flex: 1;
  min-height: 150rpx;
  font-size: 28rpx;
  line-height: 1.5;
}
.modal-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}
